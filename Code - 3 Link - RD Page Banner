<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Race Director Hub | Triathlon Learning</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #0C2340;
      --navy-deep: #081A2F;
      --navy-light: #1A3A5C;
      --red: #E31837;
      --red-hover: #FF2244;
      --white: #FFFFFF;
      --gray-50: #F7F8FA;
      --gray-100: #EBEDF2;
      --gray-200: #D1D5DE;
      --gray-600: #5A6070;
      --gold-accent: #C8A951;
      --shadow-card: 0 4px 24px rgba(12, 35, 64, 0.10), 0 1px 4px rgba(12, 35, 64, 0.06);
      --shadow-card-hover: 0 12px 40px rgba(12, 35, 64, 0.18), 0 4px 12px rgba(12, 35, 64, 0.10);
      --transition-smooth: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Source Sans 3', 'Segoe UI', sans-serif;
      background-color: var(--gray-50);
      color: var(--navy);
      -webkit-font-smoothing: antialiased;
    }

    /* ========== PAGE HEADER ========== */
    .page-header {
      background: var(--navy);
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(12, 35, 64, 0.97) 0%, rgba(26, 58, 92, 0.90) 50%, rgba(12, 35, 64, 0.95) 100%);
      z-index: 1;
    }

    /* Subtle geometric pattern overlay */
    .page-header::after {
      content: '';
      position: absolute;
      inset: 0;
      opacity: 0.04;
      background-image:
        repeating-linear-gradient(
          60deg,
          transparent,
          transparent 40px,
          rgba(255,255,255,0.5) 40px,
          rgba(255,255,255,0.5) 41px
        );
      z-index: 1;
    }

    .header-inner {
      position: relative;
      z-index: 2;
      max-width: 1100px;
      margin: 0 auto;
      padding: 56px 32px 48px;
      text-align: center;
    }

    .header-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(227, 24, 55, 0.12);
      border: 1px solid rgba(227, 24, 55, 0.25);
      border-radius: 100px;
      padding: 6px 18px;
      margin-bottom: 20px;
      animation: fadeSlideDown 0.6s ease-out both;
    }

    .header-badge span {
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--red);
    }

    .header-badge .dot {
      width: 6px;
      height: 6px;
      background: var(--red);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .page-header h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(2.2rem, 5vw, 3.2rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 14px;
      animation: fadeSlideDown 0.6s 0.1s ease-out both;
    }

    .page-header h1 .accent {
      color: var(--red);
    }

    .header-rule {
      width: 60px;
      height: 3px;
      background: var(--red);
      border: none;
      margin: 0 auto 16px;
      border-radius: 2px;
      animation: fadeSlideDown 0.6s 0.2s ease-out both;
    }

    .page-header p {
      font-size: 1.05rem;
      line-height: 1.65;
      color: rgba(255, 255, 255, 0.7);
      max-width: 600px;
      margin: 0 auto;
      font-weight: 400;
      animation: fadeSlideDown 0.6s 0.3s ease-out both;
    }

    /* ========== CARDS SECTION ========== */
    .cards-section {
      max-width: 1100px;
      margin: 0 auto;
      padding: 48px 32px 64px;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    /* ========== CARD ========== */
    .card-link {
      text-decoration: none;
      color: inherit;
      display: block;
      border-radius: 12px;
      overflow: hidden;
      background: var(--white);
      box-shadow: var(--shadow-card);
      transition:
        box-shadow var(--transition-smooth),
        transform var(--transition-smooth);
      position: relative;
      animation: cardReveal 0.5s ease-out both;
    }

    .card-link:nth-child(1) { animation-delay: 0.15s; }
    .card-link:nth-child(2) { animation-delay: 0.25s; }
    .card-link:nth-child(3) { animation-delay: 0.35s; }

    .card-link:hover {
      box-shadow: var(--shadow-card-hover);
      transform: translateY(-6px);
    }

    .card-link:focus-visible {
      outline: 3px solid var(--red);
      outline-offset: 3px;
    }

    /* Image area */
    .card-img {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--navy);
    }

    .card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .card-link:hover .card-img img {
      transform: scale(1.06);
    }

    /* Gradient overlay on image */
    .card-img::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 50%;
      background: linear-gradient(to top, rgba(12, 35, 64, 0.55), transparent);
      pointer-events: none;
    }

    /* Category tag floating on image */
    .card-tag {
      position: absolute;
      top: 14px;
      left: 14px;
      z-index: 2;
      background: var(--red);
      color: var(--white);
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 4px;
    }

    /* Placeholder when no image is loaded yet */
    .card-img .placeholder {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
    }

    .placeholder-icon {
      width: 56px;
      height: 56px;
      opacity: 0.25;
    }

    /* Card body */
    .card-body {
      padding: 24px 24px 28px;
    }

    .card-body h3 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.3rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.01em;
      line-height: 1.2;
      color: var(--navy);
      margin-bottom: 10px;
      transition: color var(--transition-smooth);
    }

    .card-link:hover .card-body h3 {
      color: var(--red);
    }

    .card-body p {
      font-size: 0.92rem;
      line-height: 1.6;
      color: var(--gray-600);
      margin-bottom: 18px;
    }

    /* CTA arrow */
    .card-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Source Sans 3', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--red);
    }

    .card-cta .arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(227, 24, 55, 0.08);
      transition:
        background var(--transition-smooth),
        transform var(--transition-smooth);
    }

    .card-cta .arrow svg {
      width: 14px;
      height: 14px;
      stroke: var(--red);
      stroke-width: 2.5;
      fill: none;
    }

    .card-link:hover .card-cta .arrow {
      background: var(--red);
      transform: translateX(3px);
    }

    .card-link:hover .card-cta .arrow svg {
      stroke: var(--white);
    }

    /* Red accent bar at bottom of card */
    .card-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: var(--red);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--transition-smooth);
    }

    .card-link:hover::after {
      transform: scaleX(1);
    }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 900px) {
      .cards-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 600px) {
      .cards-grid {
        grid-template-columns: 1fr;
        gap: 22px;
      }
      .header-inner {
        padding: 40px 20px 36px;
      }
      .cards-section {
        padding: 32px 20px 48px;
      }
    }

    /* ========== ANIMATIONS ========== */
    @keyframes fadeSlideDown {
      from {
        opacity: 0;
        transform: translateY(-12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes cardReveal {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>

  <!-- ===== PAGE HEADER ===== -->
